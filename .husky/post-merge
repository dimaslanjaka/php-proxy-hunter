#!/bin/sh

# Determine the current script directory
SCRIPT_DIR=$(dirname "$(realpath "$0")")
USER="www-data"

# Detect if running on a VPS or desktop
IS_VPS=0
if [ -f /sys/class/dmi/id/product_name ]; then
  PRODUCT_NAME=$(cat /sys/class/dmi/id/product_name 2>/dev/null | tr '[:upper:]' '[:lower:]')
  if echo "$PRODUCT_NAME" | grep -qE "vps|virtual|kvm|qemu|xen|vmware|hyper-v|cloud"; then
    IS_VPS=1
  fi
fi

# Set CWD to the parent directory of this script directory
# Use realpath to resolve the parent; if that's not a git repo,
# fall back to using git's repository root detection.
CWD=$(realpath "$SCRIPT_DIR/.." 2>/dev/null || true)
if [ -z "$CWD" ] || ! git -C "$CWD" rev-parse --show-toplevel >/dev/null 2>&1; then
  CWD=$(git rev-parse --show-toplevel 2>/dev/null || true)
fi
if [ -z "$CWD" ]; then
  echo "Error: Unable to determine repository root"
  exit 1
fi

OS=$(uname -s)
# Apply crontab
if [ "$OS" = "Linux" ] && [ $IS_VPS -eq 1 ]; then
  sudo crontab -u "$USER" "$CWD/.crontab.txt"
fi

# Determine changed files once for post-merge decisions
PREV_REF=$(git -C "$CWD" rev-parse --verify ORIG_HEAD 2>/dev/null || git -C "$CWD" rev-parse --verify HEAD^ 2>/dev/null || true)
CUR_REF=$(git -C "$CWD" rev-parse --verify HEAD 2>/dev/null || true)
CHANGED_FILES=""
if [ -n "$PREV_REF" ] && [ -n "$CUR_REF" ]; then
  CHANGED_FILES=$(git -C "$CWD" diff --name-only "$PREV_REF" "$CUR_REF")
fi
CHANGED_SUBMODULES=""

# Update only submodules whose gitlink changed
if [ -f "$CWD/.gitmodules" ]; then
  SUBMODULE_PATHS=$(git -C "$CWD" config --file "$CWD/.gitmodules" --get-regexp '^submodule\..*\.path$' 2>/dev/null | sed 's/^[^ ]* //')
  for submodule_path in $SUBMODULE_PATHS; do
    if echo "$CHANGED_FILES" | grep -Fxq "$submodule_path"; then
      CHANGED_SUBMODULES="$CHANGED_SUBMODULES $submodule_path"
    fi
  done

  if [ -n "$CHANGED_SUBMODULES" ]; then
    echo "Updating changed submodules:$CHANGED_SUBMODULES"

    # Stash local changes only in changed submodules before updating
    for submodule_path in $CHANGED_SUBMODULES; do
      if [ -n "$(git -C "$CWD/$submodule_path" status --porcelain 2>/dev/null)" ]; then
        echo "Stashing changes in submodule $submodule_path..."
        git -C "$CWD/$submodule_path" stash push -u -m "pre-submodule-update" >/dev/null 2>&1 || true
      fi
    done

    # Update only changed submodules
    for submodule_path in $CHANGED_SUBMODULES; do
      git -C "$CWD" submodule update --init --recursive -- "$submodule_path" || {
        echo "Failed to update submodule: $submodule_path"
        exit 1
      }
    done

    # Restore stashed changes in changed submodules
    for submodule_path in $CHANGED_SUBMODULES; do
      if git -C "$CWD/$submodule_path" stash list | grep -q "pre-submodule-update"; then
        echo "Restoring stashed changes in submodule $submodule_path..."
        git -C "$CWD/$submodule_path" stash pop >/dev/null 2>&1 || true
      fi
    done
  else
    echo "No submodule pointer changes detected; skipping update."
  fi
else
  echo "No submodules found, skipping update."
fi

# Run yarn only when package.json changed
ViteLockFile="$CWD/tmp/locks/.dev-server-lock"

RUN_YARN=0
if echo "$CHANGED_FILES" | grep -qE '(^|/)package\.json$'; then
  RUN_YARN=1
fi
if [ -n "$CHANGED_SUBMODULES" ]; then
  RUN_YARN=1
fi

if [ "$RUN_YARN" -eq 1 ]; then
  if command -v yarn >/dev/null 2>&1; then
    if [ $IS_VPS -eq 1 ]; then
      echo "Installing production dependencies only for VPS."
      yarn workspaces focus --production || {
        echo "Yarn install failed."
      }
    else
      echo "Installing all dependencies."
      yarn install || {
        echo "Yarn install failed."
      }
    fi
  else
    echo "Error: Yarn is not installed. Skipping yarn operations."
  fi
else
  echo "No package.json or submodule changes detected; skipping yarn."
fi

if command -v yarn >/dev/null 2>&1; then
  if [ $IS_VPS -eq 0 ]; then
    # Run the build script when the lock file is not present
    if [ ! -f "$ViteLockFile" ]; then
      echo "Vite lock not present; running build script."
      node "$CWD/bin/build-project.mjs" || {
        echo "Build project failed."
      }
    fi
  fi
fi

# Decide whether to run Composer: only when composer.json changed
COMPOSER_LOCK="$CWD/composer.lock"
COMPOSER_PHAR="$CWD/bin/composer.phar"
COMPOSER_ARGS="--no-interaction --no-audit"

if [ $IS_VPS -eq 1 ]; then
  # only install production dependencies on VPS
  echo "Detected VPS environment. Installing production dependencies only."
  COMPOSER_ARGS="--no-dev --no-interaction --no-audit"
fi

RUN_COMPOSER=0
if echo "$CHANGED_FILES" | grep -qE '(^|/)composer\.json$'; then
  RUN_COMPOSER=1
fi

if [ "$RUN_COMPOSER" -eq 1 ]; then
  echo "Composer-relevant changes detected, running composer..."
  # Composer install/update (output redirected for debugging)
  if command -v php >/dev/null 2>&1; then
    # Check if the user exists
    if id -u "$USER" >/dev/null 2>&1; then
      # Run composer commands as the specified user
      if [ -f "$COMPOSER_PHAR" ]; then
        if [ ! -f "$COMPOSER_LOCK" ]; then
          su -s /bin/sh -c "php $COMPOSER_PHAR install $COMPOSER_ARGS" "$USER" || true
        else
          su -s /bin/sh -c "php $COMPOSER_PHAR update $COMPOSER_ARGS" "$USER" || true
        fi
      else
        echo "Composer PHAR not found at $COMPOSER_PHAR; skipping composer as $USER"
      fi
    else
      # Run composer as current user if target user does not exist
      if [ -f "$COMPOSER_LOCK" ]; then
        php $COMPOSER_PHAR update $COMPOSER_ARGS || {
          echo "Composer update failed."
        }
      else
        php $COMPOSER_PHAR install $COMPOSER_ARGS || {
          echo "Composer install failed."
        }
      fi
    fi
  else
    echo "Error: PHP is not installed. Skipping composer operations."
  fi
else
  echo "No composer.json changes detected; skipping composer."
fi

# run commit history builder on non-VPS environments
if [ $IS_VPS -eq 0 ]; then
  node --no-warnings=ExperimentalWarning --loader ts-node/esm "$CWD/src/dev/git-history.builder.ts"
fi

# Fix permissions
OS=$(uname -s)
HOST=$(hostname)

# Check if running on Windows (Cygwin, MinGW, or MSYS)
if echo "$OS" | grep -q -E "CYGWIN|MINGW|MSYS"; then
  echo "No need change file permissions on windows"
# If running on Linux
elif [ "$OS" = "Linux" ]; then
  # Check if running under WSL/WSL2
  if grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null; then
    echo "Skipping permission fix on WSL/WSL2"
  # Check if the hostname contains 'DESKTOP' (likely a Windows host)
  elif echo "$HOST" | grep -q 'DESKTOP'; then
    echo "Skipping permission fix on host: $HOST"
  else
    # If nginx is installed, proceed to fix permissions
    if command -v nginx >/dev/null 2>&1; then
      # Change directory to the Git root
      cd "$CWD" || exit
      # Run the permission fix script
      bash "$CWD/bin/fix-perm"
    fi
  fi
fi

# Run database migrations
"$CWD/bin/py" "src/migrations/migrate.py" || true
