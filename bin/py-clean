#!/usr/bin/env bash
set -euo pipefail

# Detect OS
OS="$(uname -s)"

# Resolve script directory safely
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Choose working directory
if [[ "$OS" == "Linux" ]]; then
  CWD="/var/www/html"
else
  CWD="$(dirname "$SCRIPT_DIR")"
fi

# Validate directory
[[ -d "$CWD" ]] || { echo "Directory $CWD does not exist."; exit 1; }

VENV="$CWD/venv"
UNINSTALL_FILE="$CWD/uninstall.txt"

# Detect python executable
PYTHON_BIN="$(command -v python3 || command -v python || command -v python.exe)"

if [[ -z "$PYTHON_BIN" ]]; then
  echo "Python not found."
  exit 1
fi

echo "Using Python: $PYTHON_BIN"

# Create venv if missing
if [[ ! -d "$VENV" ]]; then
  echo "Creating virtual environment..."
  "$PYTHON_BIN" -m venv "$VENV"
else
  echo "Virtual environment already exists."
fi

# Activate venv (cross-platform)
if [[ "$OS" =~ ^(CYGWIN|MINGW32|MINGW64) ]]; then
  source "$VENV/Scripts/activate"
else
  source "$VENV/bin/activate"
fi

# Upgrade pip quietly (optional but useful)
python -m pip install --upgrade pip >/dev/null

# Purge pip cache
echo "Purging pip cache..."
pip cache purge || true

# Freeze installed packages
echo "Freezing installed packages..."
python -m pip freeze > "$UNINSTALL_FILE"

if [[ -s "$UNINSTALL_FILE" ]]; then
  echo "Uninstalling packages..."
  python -m pip uninstall -y -r "$UNINSTALL_FILE"
else
  echo "No packages to uninstall."
fi

rm -f "$UNINSTALL_FILE"

# Deactivate venv
deactivate

echo "Done."
